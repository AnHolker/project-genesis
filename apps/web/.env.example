# AI Provider Configuration
# Copy this file to .env.local and fill in your values

# Provider: "mock" | "openai" | "deepseek"
VITE_AI_PROVIDER=mock

# Model identifier (defaults vary by provider)
# mock: "mock"
# openai: "gpt-4o-mini"
# deepseek: "deepseek-chat"
VITE_AI_MODEL=

# API Key (required for openai, deepseek)
VITE_AI_API_KEY=

# Base URL (required for deepseek, e.g. "https://api.deepseek.com")
VITE_AI_BASE_URL=

# Response randomness (0.0–2.0, default: 0.2)
VITE_AI_TEMPERATURE=0.2

# Max output tokens (default: 800)
VITE_AI_MAX_TOKENS=800

# ⚠️ Development only — Allow browser API key usage
# NEVER enable in production. This enables dangerouslyAllowBrowser
# in the OpenAI SDK client for local development convenience.
# Default: false (disabled in all environments)
VITE_AI_ALLOW_BROWSER=false
